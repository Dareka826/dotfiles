#!/bin/sh
set -eu

command -v openssl >/dev/null 2>&1 || exit 101
command -v head >/dev/null 2>&1 || exit 101
command -v xxd >/dev/null 2>&1 || exit 101

exec 2> /dev/null
exec < /dev/zero
exec openssl enc -e -aes-256-ctr -K "$(head -c32 /dev/urandom | xxd -p -c0)" -iv "$(head -c16 /dev/urandom | xxd -p -c0)"
